  output$kegg1 <- renderPlot({
    shiny::validate( shiny::need(!is.null(input$tablefirst_rows_selected),"Please select genes first!") )
    print(input$tabsetss)
    req(input$tabsetss == "Compare clusters")
    req(input$ccaction)
    newresult <- data.subset()
    rownames(newresult) <- newresult[,1] # rownames are now hgnc symbols
    print(colnames(newresult))
    #  merged <- merge(newresult,gen, by="row.names")
    #print(colnames(merged))
    #newresult <- merged[,c(ncol(merged),3:ncol(merged))]
    selected.cutoff <-as.numeric(ccreac$logFCthreshold)
    tims=  which(grepl("logFC",colnames(newresult)))
    eg = bitr((newresult[,1]), fromType="SYMBOL", toType="ENTREZID", OrgDb="org.Hs.eg.db")
    print(selected.cutoff)
    print((selected.cutoff*(-1)))
    
    gcSample <- list()
    listindex=1
    print(tims)
    for (i in tims){
      geneList = newresult[,i]
      names(geneList) = as.character(eg$ENTREZID)
      geneList = sort(geneList, decreasing = TRUE)
      mydf <- data.frame(Entrez=names(geneList), FC=geneList)
      mydf<-na.omit(mydf)
      mydf <- mydf[abs(mydf$FC) >= selected.cutoff,]
      mydf$group <- "upregulated"
      mydf$group[mydf$FC <= (selected.cutoff*(-1)) ] <- "downregulated"
      
      gcSample[[listindex]]=(mydf[mydf$group=="upregulated",1])
      gcSample[[listindex+1]]= (mydf[mydf$group=="downregulated",1])
      listindex=listindex+2
      
      
    }
    print(gcSample)
    namesof.list <- c()
    for (i in tims){
      namesof.list <- append(namesof.list, c(paste0(colnames(newresult)[i]," upregulated" ),paste0(colnames(newresult)[i]," downregulated" ," ")))
    }
    
    names(gcSample) <- namesof.list
    print(gcSample)
    ck <- compareCluster(geneCluster = gcSample, fun = "enrichGO",OrgDb='org.Hs.eg.db', pvalueCutoff=1)
    ck <- setReadable(ck, OrgDb = 'org.Hs.eg.db', keyType="ENTREZID") #EREN it was previously org.Hs.eg.db instead of 'org.Hs.eg.db' which caused error!
    
    new_dotplot <- dotplot(ck,color="pvalue",showCategory = input$numberofcategories, font.size = input$font.slider, title=paste("Comparing GO enrichment results of upregulated and  downregulated genes in all comparison")) 
    
    new_dotplot + theme(axis.text.x = element_text(angle = 45, hjust = 1))
  })
  ############################## Correlation (eren) ----------------------------------
  corplot_func <- function(data, method){
    M = cor(data,method = method,use = "pairwise.complete.obs")
    corrplot(M, addCoef.col = 'white', col = COL2('RdBu', 200)) # colorful number
    
  }
  observeEvent(input$action_correlation,
               {
                 correlation_analysis <- result_table()
                 correlation_analysis <- correlation_analysis[as.vector(input$tablefirst_rows_selected),]
                 if (nrow(correlation_analysis) > 1){
                   if(input$p_correlation == TRUE){
                     pvalue_indices <- grep("p.value", names(correlation_analysis))
                     print(as.vector(pvalue_indices))
                     pvalue_checker <- correlation_analysis[,c(1,as.vector(pvalue_indices)),drop = FALSE]
                     pvalue_checker <- pvalue_checker %>% filter(across(-hgnc_symbol, ~. <= 0.05))
                     if(nrow(pvalue_checker) < 2){
                       showModal(modalDialog(title = "No genes left after filtering!",easyClose = TRUE))
                     }else{
                       correlation_analysis <- correlation_analysis[correlation_analysis$hgnc_symbol %in% pvalue_checker$hgnc_symbol,]
                       
                       logFC_indices <- grep("logFC", names(correlation_analysis))
                       correlation_analysis <- correlation_analysis[,as.vector(logFC_indices),drop = FALSE]
                     }
                   }
                   else{
                     logFC_indices <- grep("logFC", names(correlation_analysis))
                     correlation_analysis <- correlation_analysis[,as.vector(logFC_indices),drop = FALSE]
                   }
                   output$correlation_plot <- renderPlot(
                     corplot_func(correlation_analysis, input$method_correlation)
                   )
                 }
                 else{
                   showModal(modalDialog(title = "Please select more than 1 gene from the Analysis Tab!",easyClose = TRUE))
                 }
               })
  
