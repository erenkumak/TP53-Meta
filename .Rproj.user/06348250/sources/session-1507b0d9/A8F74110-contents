  scatter_plot <- shiny::eventReactive(input$scatter,{
    # if user wants to use all genes, it will use result_table(), but if user wants to use subsetted genes, it uses data.subset()
    if(input$scatter_material==FALSE){
      dt <- data.frame(result_table())
    }else {  dt <- data.subset() }
    
    # column names needs to be adjusted so that selected x-y axis names can be searched in them.
    # example: column name at first:"Drsp Cont_our_MCF7..p.value"
    colnames(dt) <- str_replace_all(colnames(dt), "[..]", " ")# remove any .. 
    
    # do same for selected x and y axis names, remove space
    xx <- str_replace_all(x_axis(), "[..]", " ")
    yy <- str_replace_all(y_axis(), "[..]", " ")
    
    # search selected axis names in columns of data
    x=data.frame(dt)[,grep(xx,colnames(dt))]
    
    y=data.frame(dt)[,grep(yy,colnames(dt))]
    sze=as.numeric(input$dotsize)
    
    fit_model <- lm(y ~ x, data = dt)
    
    # Create a sequence of x values for plotting the regression line across the entire range of x
    x_vals <- seq(min(x, na.rm = TRUE), max(x, na.rm = TRUE), length.out = 100)
    # Predict y values based on the model over the x_vals to get a smooth line
    y_vals <- predict(fit_model, newdata = data.frame(x = x_vals))
    
    
    max_range_x <- max(abs(range(x, na.rm = TRUE)))
    max_range_y <- max(abs(range(y, na.rm = TRUE)))
    # Before creating the plot, calculate the maximum range needed to encompass both x and y values
    #max_range <- max(abs(c(range(x, na.rm = TRUE), range(y, na.rm = TRUE))))
    
    
    # plot interactive plot 
    scatter_plot <- plot_ly() %>%
      add_markers(data = dt, x = ~x, y = ~y, text = ~dt[,1], 
                  marker = list(size = sze, color = 'rgba(255, 182, 193, .9)',
                                line = list(color = 'rgba(152, 0, 0, .8)', width = 2)),
                  textposition = 'middle right') %>%
      layout(plot_bgcolor = "#EEF2F7", xaxis = list(title = x_axis(), titlefont = list(size = 27), range = c(-max_range_x-1, max_range_x+1)), 
             yaxis = list(title = y_axis(), titlefont = list(size = 27), range = c(-max_range_y-1, max_range_y+1)), showlegend = F)
    
    # Add the regression line to the existing scatter plot
    scatter_plot <- scatter_plot %>%
      add_lines(x = ~x_vals, y = ~y_vals, line = list(color = 'blue', width = 1))
    
    # Equation of the regression line
    intercept <- round(coef(fit_model)[1], 2)
    slope <- round(coef(fit_model)[2], 2)
    r_squared <- round(summary(fit_model)$r.squared, 3)  # R-squared rounded to three decimal places
    
    # Combine the equation and R-squared into one string
    equation <- paste("y =", slope, "x +", intercept, "<br>R² =", r_squared)
    
    # Add annotation for the regression equation at the top of the plot
    scatter_plot <- scatter_plot %>%
      add_annotations(
        text = equation,
        x = 0.5, y = 1, xref = "paper", yref = "paper",
        showarrow = FALSE,
        font = list(family = "Arial, sans-serif", size = 30, color = "blue"),
        bgcolor = "white", bordercolor = "black", borderwidth = 1, borderpad = 4,
        align = "center"
      )
    
  })
