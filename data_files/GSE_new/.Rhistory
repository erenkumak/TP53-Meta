library(Seurat)
library(tidyverse)
library(egg) # for theme_article (plotting theme)
library(ggplot2)
library(ggrepel)
GSE181987_seurat <- readRDS("GSE181987_zf_WT_MPIMT_liver.rds")
GSE181987_seurat$Cell.type <- Idents(GSE181987_seurat)
GSE181987_seurat$batch <- GSE181987_seurat$orig.ident
condition <- list(GSE181987_seurat$orig.ident)
modified_list <- lapply(condition, function(x) substr(x, 1, nchar(x) - 1))
GSE181987_seurat$condition <- unlist(modified_list)
# pseudobulk the counts based on donor and batch (not cell type!!)
pseudo_GSE181987 <- AggregateExpression(GSE181987_seurat, assays = "RNA", return.seurat = T, group.by = c("condition", "batch"))
tail(Cells(pseudo_GSE181987))
# each 'cell' is a batch/donor-condition pseudobulk profile
pseudo_GSE181987$celltype.stim <- pseudo_GSE181987$condition
Idents(pseudo_GSE181987) <- "celltype.stim"
MPI_MTvsWT <- FindMarkers(pseudo_GSE181987, ident.1 = "MPI-MT", ident.2 = "WT", test.use = "DESeq2")
pseudo_GSE181987 <- AggregateExpression(GSE181987_seurat, assays = "RNA", return.seurat = T, group.by = c("condition", "batch", "Cell.type"))
pseudo_GSE181987$celltype.stim <- paste(pseudo_GSE181987$Cell.type, pseudo_GSE181987$condition, sep = "_")
Idents(pseudo_GSE181987) <- "celltype.stim"
dg_expressed <- list()
cell_types <- unique(pseudo_GSE181987$Cell.type)
for(i in 1:length(unique(pseudo_GSE181987$Cell.type))){
ident.1 = paste(cell_types[[i]],"MPI-MT", sep = "_")
ident.2 = paste(cell_types[[i]],"WT", sep = "_")
try(dg_expressed[[i]] <- FindMarkers(pseudo_GSE181987, ident.1 = ident.1, ident.2 = ident.2, test.use = "DESeq2"))
print(cell_types[[i]])
}
#"zAgr2+" is not included
install.packages("xlsx")
library(xlsx)
wb <- createWorkbook(type = "xlsx")
options(java.parameters = "-Xmx8000m")
sheet <- createSheet(wb, sheetName = "MPI-MT VS WT")
addDataFrame(MPI_MTvsWT, sheet)
for (i in 1:(length(cell_types)-1)){
print(cell_types[i])
sheet <- createSheet(wb, sheetName = cell_types[i])
addDataFrame(dg_expressed[[i]], sheet)
}
