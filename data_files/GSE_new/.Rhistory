library(png)
library(imager)
all_combinations <- expand.grid(replicate(7, c(0,1), simplify = FALSE))
all_combinations <- apply(all_combinations, 1, function(row) paste(row, collapse = ""))
list_of_matrices <- list()
for (i in all_combinations){
invisible({
a <- log2FC.matrix_c %>% filter(code == i)
b <- a[3:16]
if (nrow(a) == 0){
next
}
prefix <- i
new_row_names <- paste0(prefix,rownames(b))
rownames(b) <- new_row_names
new_column_names <- paste0(prefix,colnames(b))
colnames(b) <- new_column_names
logFC_b <- b[, grepl(".logFC", names(b))]
colnames(logFC_b) <- gsub(".logFC", "", colnames(logFC_b))
htmp <- pheatmap(color = colorRampPalette(colors = c("blue", "white", "red"))(20),mat =logFC_b,breaks = seq(-6,6,0.6), fontsize_row = 5, fontsize_col = 12, border_color = "white", legend = TRUE,cluster_cols = TRUE, cluster_rows = FALSE, show_rownames= TRUE,show_colnames = TRUE, main = as.character(i))
list_of_matrices[[length(list_of_matrices)+1]] <- i
# Save the heatmap as a PNG file
heatmap_filename <- paste0("realheatmaps/",i,".png")
png(heatmap_filename, width = 800, height = 600)
print(htmp)
dev.off()
})
}
library(pheatmap)
library(png)
library(imager)
all_combinations <- expand.grid(replicate(7, c(0,1), simplify = FALSE))
all_combinations <- apply(all_combinations, 1, function(row) paste(row, collapse = ""))
list_of_matrices <- list()
for (i in all_combinations){
invisible({
a <- log2FC.matrix_c %>% filter(code == i)
b <- a[3:16]
if (nrow(a) == 0){
next
}
prefix <- i
new_row_names <- paste0(prefix,rownames(b))
rownames(b) <- new_row_names
new_column_names <- paste0(prefix,colnames(b))
colnames(b) <- new_column_names
logFC_b <- b[, grepl(".logFC", names(b))]
colnames(logFC_b) <- gsub(".logFC", "", colnames(logFC_b))
htmp <- pheatmap(color = colorRampPalette(colors = c("blue", "white", "red"))(20),mat =logFC_b,breaks = seq(-6,6,0.6), fontsize_row = 5, fontsize_col = 12, border_color = "white", legend = TRUE,cluster_cols = TRUE, cluster_rows = FALSE, show_rownames= TRUE,show_colnames = TRUE, main = as.character(i))
list_of_matrices[[length(list_of_matrices)+1]] <- i
# Save the heatmap as a PNG file
heatmap_filename <- paste0("realheatmaps/",i,".png")
png(heatmap_filename, width = 1280, height = 720)
print(htmp)
dev.off()
})
}
