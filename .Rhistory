load_meta <- function(id){
a  <- getGEO(id, GSEMatrix = TRUE) #get the meta data via accession.
a  <- pData(a[[1]]) #get the df portion
return(a) #return it
}
a <- load_meta("GSE162694")
library(GEOquery)
a <- load_meta("GSE162694")
View(a)
table(a$geo_accession)
table(a$`nas score:ch1`
)
